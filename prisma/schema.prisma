generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  BUYER
  ARTIST
  CHARITY
  ADMIN
}

enum ProductType {
  SIMPLE
  VARIABLE
  GROUPED
  VIRTUAL
  DOWNLOADABLE
}

enum ProductStatus {
  DRAFT
  ACTIVE
  SOLD
  SUSPENDED
}

enum ProductCategory {
  ARTWORK
  EBOOK
  MUSIC
  GRAPHIC
  ANIMATION
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum MessageType {
  APPRECIATION
  NEWSLETTER
  RESOURCE_SHARE
}

enum ResourceVisibility {
  PUBLIC
  FUNDERS_ONLY
}

enum FunderSource {
  NEWSLETTER
  DONATION
  MANUAL
}

enum CouponType {
  PERCENT
  FIXED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id                String               @id @default(cuid())
  email             String               @unique
  passwordHash      String?
  emailVerified     DateTime?
  verificationCode  String?
  role              UserRole             @default(BUYER)
  firstName         String?
  lastName          String?
  avatarUrl         String?
  phone             String?
  deactivatedAt     DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  artistProfile     ArtistProfile?
  charityProfile    CharityProfile?
  orders            Order[]
  reviews           Review[]
  wishlistItems     WishlistItem[]
  funderRelations   FunderRelationship[]
  notifications     Notification[]
  tcAcceptances     TCAcceptance[]
  auditLogs         AuditLog[]
  reviewedDocuments CharityDocument[]
}

model ArtistProfile {
  id              String                     @id @default(cuid())
  userId          String                     @unique
  user            User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName     String
  avatarUrl       String?
  artistStatement String?                    @db.Text
  biography       String?                    @db.Text
  location        String?
  socialLinks     Json?
  exhibitions     Json[]                     @default([])
  awards          Json[]                     @default([])
  verified        Boolean                    @default(false)
  sdgIds          Int[]                      @default([])
  totalSold       Decimal                    @default(0) @db.Decimal(12, 2)
  artworkCount    Int                        @default(0)
  joinedYear      Int?
  products        Product[]
  partnerships    ArtistCharityPartnership[]
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt
}

model CharityProfile {
  id              String                     @id @default(cuid())
  userId          String                     @unique
  user            User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  logo            String?
  mission         String?                    @db.Text
  registrationNo  String?
  sdgIds          Int[]                      @default([])
  verified        Boolean                    @default(false)
  raised          Decimal                    @default(0) @db.Decimal(12, 2)
  target          Decimal                    @default(0) @db.Decimal(12, 2)
  funderCount     Int                        @default(0)
  websiteUrl      String?
  products        Product[]
  partnerships    ArtistCharityPartnership[]
  messages        CharityMessage[]
  templates       MessageTemplate[]
  documents       CharityDocument[]
  resources       CharityResource[]
  funderRelations FunderRelationship[]
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt
}

model ArtistCharityPartnership {
  id        String         @id @default(cuid())
  artistId  String
  charityId String
  artist    ArtistProfile  @relation(fields: [artistId], references: [id])
  charity   CharityProfile @relation(fields: [charityId], references: [id])
  status    String         @default("active")
  createdAt DateTime       @default(now())

  @@unique([artistId, charityId])
}

model Product {
  id              String             @id @default(cuid())
  artistId        String
  artist          ArtistProfile      @relation(fields: [artistId], references: [id])
  charityId       String?
  charity         CharityProfile?    @relation(fields: [charityId], references: [id])
  title           String
  slug            String             @unique
  description     String?            @db.Text
  productType     ProductType        @default(SIMPLE)
  category        ProductCategory    @default(ARTWORK)
  basePrice       Decimal            @db.Decimal(10, 2)
  comparePrice    Decimal?           @db.Decimal(10, 2)
  status          ProductStatus      @default(DRAFT)
  sku             String?            @unique
  stockQuantity   Int?
  medium          String?
  year            Int?
  dimensions      String?
  fileUrl         String?
  fileFormat      String?
  previewUrl      String?
  pages           Int?
  certificateUrl  String?
  autoCertificate Boolean            @default(false)
  certificateId   String?            @unique
  sdgIds          Int[]              @default([])
  images          Json[]             @default([])
  gallery         Json?
  videoUrl        String?
  tags            String[]           @default([])
  featured        Boolean            @default(false)
  upsellIds       String[]           @default([])
  crossSellIds    String[]           @default([])
  variations      ProductVariation[]
  addons          ProductAddon[]
  orderItems      OrderItem[]
  reviews         Review[]
  wishlistItems   WishlistItem[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

model ProductVariation {
  id                   String      @id @default(cuid())
  productId            String
  product              Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  attributeCombination Json
  price                Decimal     @db.Decimal(10, 2)
  sku                  String?
  stockQuantity        Int?
  imageUrl             String?
  orderItems           OrderItem[]
}

model ProductAddon {
  id            String   @id @default(cuid())
  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  fieldType     String
  label         String
  required      Boolean  @default(false)
  options       Json?
  priceModifier Decimal? @db.Decimal(10, 2)
  sortOrder     Int      @default(0)
}

model Order {
  id              String      @id @default(cuid())
  buyerId         String?
  buyer           User?       @relation(fields: [buyerId], references: [id])
  buyerEmail      String
  status          OrderStatus @default(PENDING)
  totalAmount     Decimal     @db.Decimal(10, 2)
  shippingAmount  Decimal     @default(0) @db.Decimal(10, 2)
  platformFee     Decimal     @default(0) @db.Decimal(10, 2)
  charitySplit    Decimal     @default(0) @db.Decimal(10, 2)
  shippingAddress Json?
  paymentRef      String?
  refundRequested Boolean     @default(false)
  refundedAt      DateTime?
  items           OrderItem[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model OrderItem {
  id              String            @id @default(cuid())
  orderId         String
  order           Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId       String
  product         Product           @relation(fields: [productId], references: [id])
  variationId     String?
  variation       ProductVariation? @relation(fields: [variationId], references: [id])
  quantity        Int
  unitPrice       Decimal           @db.Decimal(10, 2)
  addonSelections Json?
  charitySplitAmt Decimal           @default(0) @db.Decimal(10, 2)
  platformFeeAmt  Decimal           @default(0) @db.Decimal(10, 2)
}

model Review {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  rating    Int
  text      String?  @db.Text
  createdAt DateTime @default(now())
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

model FunderRelationship {
  id        String         @id @default(cuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id])
  charityId String
  charity   CharityProfile @relation(fields: [charityId], references: [id])
  source    FunderSource   @default(NEWSLETTER)
  optedInAt DateTime       @default(now())

  @@unique([userId, charityId])
}

model CharityMessage {
  id             String         @id @default(cuid())
  charityId      String
  charity        CharityProfile @relation(fields: [charityId], references: [id])
  messageType    MessageType
  subject        String
  bodyHtml       String         @db.Text
  sentAt         DateTime       @default(now())
  recipientCount Int            @default(0)
}

model MessageTemplate {
  id        String         @id @default(cuid())
  charityId String
  charity   CharityProfile @relation(fields: [charityId], references: [id])
  name      String
  subject   String
  bodyHtml  String         @db.Text
  isSystem  Boolean        @default(false)
  createdAt DateTime       @default(now())
}

model CharityResource {
  id         String             @id @default(cuid())
  charityId  String
  charity    CharityProfile     @relation(fields: [charityId], references: [id])
  title      String
  fileUrl    String
  fileType   String
  visibility ResourceVisibility @default(PUBLIC)
  uploadedAt DateTime           @default(now())
}

model CharityDocument {
  id           String         @id @default(cuid())
  charityId    String
  charity      CharityProfile @relation(fields: [charityId], references: [id], onDelete: Cascade)
  label        String
  storagePath  String
  uploadedAt   DateTime       @default(now())
  reviewStatus ReviewStatus   @default(PENDING)
  reviewedBy   String?
  reviewer     User?          @relation(fields: [reviewedBy], references: [id])
  reviewedAt   DateTime?
  reviewNote   String?        @db.Text
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  icon      String?
  title     String
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model TCAcceptance {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       UserRole
  version    String
  acceptedAt DateTime @default(now())
}

model SiteSetting {
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id         String   @id @default(cuid())
  adminId    String
  admin      User     @relation(fields: [adminId], references: [id])
  action     String
  targetType String
  targetId   String
  before     Json?
  after      Json?
  createdAt  DateTime @default(now())

  @@index([targetType, targetId])
  @@index([adminId])
  @@index([createdAt])
}

model PageContent {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String?
  body      Json
  updatedAt DateTime @updatedAt
  updatedBy String?
}

model TeamMember {
  id        String   @id @default(cuid())
  name      String
  role      String
  // Despite the name, holds the ready-to-render public URL, not a bare
  // storage key — `avatars` is a public bucket, and every other public-
  // bucket field in this schema (ArtistProfile.avatarUrl, CharityProfile.
  // logo) stores the full URL the Uploader component hands back. Matches
  // that convention so the future admin form is a drop-in, same as those.
  photoPath String?
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TermsDocument {
  id          String   @id @default(cuid())
  role        UserRole
  version     String
  body        String   @db.Text
  publishedAt DateTime @default(now())
  createdBy   String

  @@unique([role, version])
}

model CategoryMeta {
  key       ProductCategory @id
  label     String
  icon      String?
  color     String?
  bg        String?
  sortOrder Int             @default(0)
  active    Boolean         @default(true)
  updatedAt DateTime        @updatedAt
}

model Coupon {
  id         String     @id @default(cuid())
  code       String     @unique
  type       CouponType
  value      Decimal    @db.Decimal(10, 2)
  minSpend   Decimal    @default(0) @db.Decimal(10, 2)
  usageLimit Int?
  usedCount  Int        @default(0)
  validFrom  DateTime?
  validUntil DateTime?
  active     Boolean    @default(true)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}
