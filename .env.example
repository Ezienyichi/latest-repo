# ═══ Change Art Gallery — Environment Variables ═══
# Set these in Netlify Dashboard → Site Settings → Environment Variables

# Database (Supabase / Neon / Railway PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/change_art_gallery

# Auth
JWT_SECRET=generate-a-long-random-string-here
JWT_EXPIRES_IN=7d

# Stripe (optional — demo mode works without)
STRIPE_SECRET_KEY=sk_test_your_stripe_key
VITE_STRIPE_PK=pk_test_your_stripe_key

# Supabase Storage — server-only, used by the Worker to mint signed upload/
# download URLs (functions/_lib/storage.js) and to compute public URLs for
# public buckets. SUPABASE_SERVICE_ROLE_KEY is a high-privilege secret —
# never prefix it VITE_, never ship it to the browser. The browser never
# needs any Supabase credential at all: it only ever sees the one-time
# signed URL the Worker hands it.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
